#!/bin/sh
# Section-map enforcement on commit. Any new top-level binding in
# index.html that lacks a [SEC:...] marker gets a [SEC:JS:TODO:<Name>]
# placeholder inserted directly above it; the placeholder is then re-
# staged so it lands in this commit. Recategorize the TODO later
# (JS:SRV:* / JS:UTIL:* / JS:CTRL:* / JS:STATE:* / etc.) and add the
# new ID to the TECHNICAL MAP at the top of index.html.
#
# Activation: `git config core.hooksPath .githooks` (done automatically
# by the `prepare` script in package.json the next time you run
# `npm install` — assuming npm scripts aren't disabled).

set -e

# Only run if index.html has a staged add/copy/modify/rename. The
# --diff-filter=ACMR excludes 'D' so we don't try to --fix a file that's
# being deleted (it's gone from the working tree and readFileSync would
# crash).
git diff --cached --diff-filter=ACMR --name-only | grep -q '^index\.html$' || exit 0

# Partial-stage case: working tree differs from the index (the user ran
# `git add -p` or staged only some hunks). Auto-fix would write to the
# working tree and then `git add index.html` would sweep all the unstaged
# hunks into the commit too. Refuse to auto-fix in that case; just check
# the staged blob and fail with a helpful message if it's missing markers.
if ! git diff --quiet -- index.html; then
    if ! git show :index.html | node tools/check-map.js --stdin; then
        echo ""
        echo "index.html has both staged AND unstaged changes; section-map"
        echo "auto-fix is disabled here to avoid pulling unstaged hunks"
        echo "into the commit. Either:"
        echo "  - stage index.html fully (git add index.html) and recommit, or"
        echo "  - run 'node tools/check-map.js --fix' yourself, then"
        echo "    'git add -p' the new marker line(s) and recommit."
        exit 1
    fi
    exit 0
fi

# Clean case: working tree matches the index. Safe to --fix and re-stage.
node tools/check-map.js --fix

# If --fix changed the working tree, stage the change so it goes in the
# commit. No-op if nothing changed.
git add index.html
